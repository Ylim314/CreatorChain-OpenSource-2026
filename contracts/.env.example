# Private key for testnet/mainnet deployments
PRIVATE_KEY=

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=

# Legacy archived workspace private keys (comma-separated, optional)
# LEGACY_LOCAL_PRIVATE_KEYS=0xkey1,0xkey2
