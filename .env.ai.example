# CreatorChain AI模型配置 - 环境变量模板
# 请复制此文件为 .env 并填写你的API密钥

# ============================================
# 通义千问 (阿里云DashScope) - 推荐用于答辩
# ============================================
# 获取地址: https://dashscope.console.aliyun.com/apiKey
# 免费额度: 新用户90天内各100万tokens
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 通义千问API基础URL (一般不需要修改)
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ============================================
# 豆包 (字节跳动火山引擎) - 推荐用于答辩
# ============================================
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
# 注意: 豆包需要先创建推理接入点,然后获取endpoint_id
ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型endpoint配置 (每个模型需要单独配置)
# 在火山引擎控制台创建推理接入点后获取
DOUBAO_PRO_ENDPOINT_ID=ep-xxxxxxxxxxxxxxxx
DOUBAO_LITE_ENDPOINT_ID=ep-xxxxxxxxxxxxxxxx
DOUBAO_VISION_ENDPOINT_ID=ep-xxxxxxxxxxxxxxxx

# ============================================
# DeepSeek (可选)
# ============================================
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ============================================
# Kimi (月之暗面) (可选)
# ============================================
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ============================================
# 智谱AI GLM (可选)
# ============================================
GLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ============================================
# OpenAI (国际模型,可选)
# ============================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# 通用配置
# ============================================
# AI引擎超时设置(秒)
AI_REQUEST_TIMEOUT=60

# 默认使用的模型(用于答辩演示)
DEFAULT_TEXT_MODEL=qwen-plus
DEFAULT_IMAGE_MODEL=qwen-image-plus

# 是否启用模型缓存
ENABLE_MODEL_CACHE=true

# 日志级别
AI_LOG_LEVEL=info

# ============================================
# 答辩演示配置建议
# ============================================
# 文本生成推荐: qwen-plus (性价比高,效果好)
# 图像生成推荐: qwen-image-plus (中文文本渲染强)
# 艺术创作推荐: wan2.5-t2i-preview (画质精美)
# 长文本推荐: qwen-plus (支持100万token)
# 经济实惠推荐: doubao-lite-32k (豆包轻量版)

# ============================================
# 重要提示
# ============================================
# 1. 通义千问和豆包都是国产模型,合规性好
# 2. 新用户有免费额度,足够答辩使用
# 3. 请勿将此文件提交到版本控制系统
# 4. 生产环境建议使用环境变量或密钥管理服务
# 5. 定期检查API密钥使用情况和余额
